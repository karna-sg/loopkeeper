# Copy to deploy/loopkeeper.env, `chmod 600`, and fill in. NEVER commit real values.
# (deploy/loopkeeper.env is gitignored.)

HOST=0.0.0.0
PORT=8080
LOOPKEEPER_DATA_DIR=/data
LOOPKEEPER_TZ=Asia/Kolkata

# Must equal https://<LK_HOST> and match your OAuth redirect URIs exactly.
LOOPKEEPER_PUBLIC_URL=https://13-49-22-7.sslip.io

# Bearer token the iOS app sends.  Generate:  openssl rand -hex 24
LOOPKEEPER_API_TOKEN=

# --- AI provider (auto-selects openai when OPENAI_API_KEY is set) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# To use Claude instead:  ANTHROPIC_API_KEY=sk-ant-...  and  LLM_PROVIDER=anthropic

# Token-vault encryption key — base64 of 32 random bytes. Generate ONCE, keep stable forever
# (changing it invalidates stored tokens).  Generate:  openssl rand -base64 32
LOOPKEEPER_MASTER_KEY=

# --- OAuth apps (read-only scopes) ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =====================================================================================
# Phase 2 — engineering orchestration (read by both the api and the worker container).
# Leave blank to keep the feature gracefully disabled (GET /tasks → 503, no Jira section).
# =====================================================================================

# Claude Code (the agent) — the WORKER needs this; the api reuses it for extraction too.
ANTHROPIC_API_KEY=
# ENG_CLAUDE_MODEL=claude-sonnet-4-6      # optional override; else the CLI default

# Jira OAuth (3LO) app — READ-ONLY scopes (read:jira-work, read:jira-user, offline_access).
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# Your Jira accountId — assignee-gate identity + GET /tasks filter. Find via GET /myself.
LOOPKEEPER_JIRA_ACCOUNT_ID=

# GitHub — fine-grained PAT scoped to ONLY the LoopKeeper repo (contents + pull-requests: r/w).
GITHUB_TOKEN=
GITHUB_REPO=karna/loopkeeper
GITHUB_BASE_BRANCH=main
# ENG_REPO_URL=https://github.com/karna/loopkeeper.git   # optional; derived from GITHUB_REPO

# Worker caps (cost + runaway protection) and cadence.
ENG_MAX_ITERATIONS=6
ENG_TASK_BUDGET_USD_CENTS=500
ENG_MAX_REVIEW_ROUNDS=5
ENG_RUN_TIMEOUT_MS=1200000
ENG_MAX_CONCURRENT=1
LOOPKEEPER_WORKER_POLL_SEC=15
LOOPKEEPER_JIRA_SYNC_EVERY_MIN=10
LOOPKEEPER_PR_POLL_EVERY_MIN=5

# Deploy (worker SSHes the prod host after a gated merge). OFF until verified.
DEPLOY_ENABLED=0
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=deploy
DEPLOY_SSH_KEY_PATH=/root/.ssh/id_ed25519
DEPLOY_REMOTE_PATH=/opt/loopkeeper
DEPLOY_BRANCH=main
